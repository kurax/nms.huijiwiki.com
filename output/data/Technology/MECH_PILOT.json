  "Name": {
    "English": "MINOTAUR AI PILOT",
    "SimplifiedChinese": "弥诺陶洛斯人工智能驾驶员",
    "TraditionalChinese": "彌諾陶洛斯人工智慧駕駛員"
  },
  "NameLower": {
    "English": "Minotaur AI Pilot",
    "SimplifiedChinese": "弥诺陶洛斯人工智能驾驶员",
    "TraditionalChinese": "彌諾陶洛斯人工智慧駕駛員"
