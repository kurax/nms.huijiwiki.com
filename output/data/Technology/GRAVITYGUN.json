  "Name": {
    "English": "GRAVITINO COIL",
    "SimplifiedChinese": "引力微子线圈",
    "TraditionalChinese": "伴重力子線圈"
  },
  "NameLower": {
    "English": "Gravitino Coil",
    "SimplifiedChinese": "引力微子线圈",
    "TraditionalChinese": "伴重力子線圈"
