  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-catalyst\">Sodium</span> is harvested from yellow plants found on all planets. Locate sodium-rich plants with the <span class=\"name name-technology\">Scanner</span> (<span class=\"name name-img\">SCAN</span>).",
    "SimplifiedChinese": "<span class=\"name name-catalyst\">钠</span>可以从所有行星上都有的黄色植物中采集。使用<span class=\"name name-technology\">扫描仪</span>（<span class=\"name name-img\">SCAN</span>）定位富含钠的植物。",
    "TencentChinese": "<span class=\"name name-catalyst\">钠</span>可以从所有行星上都有的黄色植物中采集。使用<span class=\"name name-technology\">扫描仪</span>（<span class=\"name name-img\">SCAN</span>）定位富含钠的植物。",
    "TraditionalChinese": "<span class=\"name name-catalyst\">鈉</span>可從所有星球上的黃色植物中採收。用<span class=\"name name-technology\">掃描器</span>（<span class=\"name name-img\">SCAN</span>）找出富有鈉的植物。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-catalyst\">Sodium</span> is harvested from yellow plants found on all planets<br>Locate sodium-rich plants with the <span class=\"name name-technology\">Scanner</span> (<span class=\"name name-img\">SCAN</span>)",
    "SimplifiedChinese": "<span class=\"name name-catalyst\">钠</span>可以从所有行星上都有的黄色植物中采集。<br>使用<span class=\"name name-technology\">扫描仪</span>（<span class=\"name name-img\">SCAN</span>）定位富含钠的植物",
    "TraditionalChinese": "<span class=\"name name-catalyst\">鈉</span>可以從所有行星上都有的黃色植物中採集<br>使用<span class=\"name name-technology\">掃描器</span> (<span class=\"name name-img\">SCAN</span>) 找出富含鈉的植物"
  },
