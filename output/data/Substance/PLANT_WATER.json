  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Kelp Sacs</span> are harvested from <span class=\"name name-technology\">underwater</span> <span class=\"name name-tradeable\">Candle Kelp</span> plants.<br>Increase marine efficiency by upgrading the Exosuit <span class=\"name name-technology\">Aeration Membrane</span>, or refill oxygen supplies in suit by consuming <span class=\"name name-tradeable\">Kelp Sacs</span> from the vine.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">海藻袋</span>能从<span class=\"name name-technology\">水下</span>生长的<span class=\"name name-tradeable\">烛光藻</span>植物上采集到。<br>升级套装的<span class=\"name name-technology\">曝气膜</span>或使用来自藤蔓的<span class=\"name name-tradeable\">海藻袋</span>重新补给氧气，以提高在海洋中的效率。",
    "TencentChinese": "<span class=\"name name-tradeable\">海藻袋</span>能从<span class=\"name name-technology\">水下</span>生长的<span class=\"name name-tradeable\">烛光藻</span>植物上采集到。<br>升级套装的<span class=\"name name-technology\">曝气膜</span>或使用来自藤蔓的<span class=\"name name-tradeable\">海藻袋</span>重新补给氧气，以提高在海洋中的效率。",
    "TraditionalChinese": "自<span class=\"name name-technology\">水底</span><span class=\"name name-tradeable\">蠟燭巨藻</span>植物上取得的<span class=\"name name-tradeable\">巨藻囊</span>。<br>透過強化套裝升級<span class=\"name name-technology\">曝氣黏膜</span>或透過<span class=\"name name-tradeable\">巨藻囊</span>藤部在強化套裝中補充氧氣來源以提升海洋效能。"
  },
