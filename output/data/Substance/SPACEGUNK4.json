  },
  "PinObjectiveTip": {
    "English": "Locate <span class=\"name name-special\">Living Slime</span> in neglected corners of the universe, or attempt creation of your own pulsating goo by processing <span class=\"name name-special\">Atlantideum</span> and <span class=\"name name-stellar\">Mordite</span> with a <span class=\"name name-technology\">Medium</span> or <span class=\"name name-technology\">Large Refiner</span>.",
    "SimplifiedChinese": "在宇宙的偏僻角落定位<span class=\"name name-special\">活体黏质</span>，或者尝试使用<span class=\"name name-technology\">中型</span>或<span class=\"name name-technology\">大型精炼机</span>加工<span class=\"name name-special\">亚特拉迪姆</span>以及<span class=\"name name-stellar\">腐藤</span>来自己生产不停搏动的粘液。",
    "TraditionalChinese": "在太空中受忽略的角落找到<span class=\"name name-special\">活軟泥</span>，或嘗試用<span class=\"name name-technology\">中型</span>或<span class=\"name name-technology\">大型精製機</span>將<span class=\"name name-special\">亞特蘭提德鋼</span>與<span class=\"name name-stellar\">歿鹽</span>一起處理，製作自己的脈動黏液。"
  },
  "PinObjectiveMessage": {
    "English": "Process <span class=\"name name-special\">Atlantideum</span> and <span class=\"name name-stellar\">Mordite</span> with a <span class=\"name name-technology\">Medium</span> or <span class=\"name name-technology\">Large Refiner</span>",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">中型</span>或<span class=\"name name-technology\">大型精炼机</span>加工<span class=\"name name-special\">亚特拉迪姆</span>与<span class=\"name name-stellar\">腐藤</span>",
    "TraditionalChinese": "使用<span class=\"name name-technology\">中型</span>或<span class=\"name name-technology\">大型精製機</span>處理<span class=\"name name-special\">亞特蘭提德鋼</span>和<span class=\"name name-stellar\">歿鹽</span>"
  },
