  "PinObjectiveTip": {
    "English": "<span class=\"name name-fuel\">Condensed Carbon</span> is found in crystal form on most planets. Locate carbon crystals with the <span class=\"name name-technology\">Scanner</span> (<span class=\"name name-img\">SCAN</span>). Large deposits may require use of an <span class=\"name name-technology\">Advanced Mining Laser</span>.<br>Condensed Carbon can be created from Carbon in a <span class=\"name name-technology\">Refiner</span>.",
    "SimplifiedChinese": "<span class=\"name name-fuel\">浓缩碳</span>在大多数行星上以晶体形式出现。使用<span class=\"name name-technology\">扫描仪</span>（<span class=\"name name-img\">SCAN</span>）定位碳晶体。大形矿床可能需要采用<span class=\"name name-technology\">高级开采光束</span>开采。<br>可在<span class=\"name name-technology\">精炼机</span>中用碳制得浓缩碳。",
    "TraditionalChinese": "<span class=\"name name-fuel\">濃縮碳</span>在多數的星球上是以結晶形式出現。使用<span class=\"name name-technology\">掃描器</span>（<span class=\"name name-img\">SCAN</span>）找出碳結晶。大型資源產地可能需要用<span class=\"name name-technology\">改良採礦雷射</span>。<br>用<span class=\"name name-technology\">精製機</span>可將碳製造成濃縮碳。"
  },
  "PinObjectiveMessage": {
    "English": "Locate <span class=\"name name-fuel\">condensed carbon</span> crystals with the <span class=\"name name-technology\">Scanner</span> (<span class=\"name name-img\">SCAN</span>)<br>Condensed carbon can be created from carbon in a <span class=\"name name-technology\">Refiner</span>",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">扫描仪</span>（<span class=\"name name-img\">SCAN</span>）定位<span class=\"name name-fuel\">浓缩碳</span><br>你可以在<span class=\"name name-technology\">精炼机</span>中制作浓缩碳",
    "TraditionalChinese": "使用<span class=\"name name-technology\">掃描器</span> (<span class=\"name name-img\">SCAN</span>) 找出<span class=\"name name-fuel\">濃縮碳</span><br>使用<span class=\"name name-technology\">精製機</span>可將碳加工製作成濃縮碳"
