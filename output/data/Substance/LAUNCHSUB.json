  "PinObjectiveTip": {
    "English": "<span class=\"name name-technology\">Di-hydrogen</span> is found in crystal form on most planets. Locate di-hydrogen crystals with the <span class=\"name name-technology\">Scanner</span> (<span class=\"name name-img\">SCAN</span>). Large deposits may require use of an <span class=\"name name-technology\">Advanced Mining Laser</span>.",
    "SimplifiedChinese": "<span class=\"name name-fuel\">二氢</span>在大多数行星上以晶体形式出现。使用<span class=\"name name-technology\">扫描仪</span>（<span class=\"name name-img\">SCAN</span>）定位二氢晶体。大形矿床可能需要采用<span class=\"name name-technology\">高级开采光束</span>开采。",
    "TencentChinese": "<span class=\"name name-fuel\">二氢</span>在大多数行星上以晶体形式出现。使用<span class=\"name name-technology\">扫描仪</span>（<span class=\"name name-img\">SCAN</span>）定位二氢晶体。大形矿床可能需要采用<span class=\"name name-technology\">高级开采光束</span>开采。",
    "TraditionalChinese": "<span class=\"name name-technology\">二氫</span>在多數的星球上是以結晶形式出現。使用<span class=\"name name-technology\">掃描器</span>（<span class=\"name name-img\">SCAN</span>）找出二氫結晶。大型資源產地可能需要用<span class=\"name name-technology\">改良採礦雷射</span>。"
  },
  "PinObjectiveMessage": {
    "English": "Locate <span class=\"name name-technology\">Di-hydrogen</span> crystals with the <span class=\"name name-technology\">Scanner</span> (<span class=\"name name-img\">SCAN</span>)<br>Harvest the crystals with the Mining Laser (<span class=\"name name-img\">ATTACK</span>)",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">扫描仪</span>（<span class=\"name name-img\">SCAN</span>）定位<span class=\"name name-technology\">二氢</span>晶体<br>使用开采激光（<span class=\"name name-img\">ATTACK</span>）采集晶体",
    "TraditionalChinese": "使用<span class=\"name name-technology\">掃描器</span> (<span class=\"name name-img\">SCAN</span>) 找出<span class=\"name name-technology\">二氫</span>結晶<br>使用採礦雷射 (<span class=\"name name-img\">ATTACK</span>) 採集晶體"
