  "PinObjective": {
    "English": "Gather Atlantideum",
    "SimplifiedChinese": "收集亚特拉迪姆",
    "TencentChinese": "收集亚特拉迪姆",
    "TraditionalChinese": "收集亞特蘭提德鋼"
  },
  "PinObjectiveTip": {
    "English": "This ethereal substance spills from the bodies of <span class=\"name name-special\">corrupted Sentinels</span> as they fall.  Engage corrupted Sentinel forces in combat to release Atlantideum from their shells, or harvest it from the crystals that litter their foul worlds.",
    "SimplifiedChinese": "来源于<span class=\"name name-special\">腐化护卫</span>残骸的缥缈物质。腐化护卫部队进行战斗将使它们的外壳释放亚特拉迪姆，或者你也可以在不谐星球寻找并收获晶体。",
    "TraditionalChinese": "隨著<span class=\"name name-special\">受腐蝕巡警</span>死亡，這種空靈的物質從它們的體內潑灑了出來。與受腐蝕巡警部隊交戰，釋放藏在其外殼內的亞特蘭提德鋼，或從它們惡劣世界隨處可見的水晶上採集。"
  },
  "PinObjectiveMessage": {
    "English": "Harvest from the canisters dropped by <span class=\"name name-special\">corrupted Sentinels</span> as they fall in combat<br>Can be gathered from purple crystals on <span class=\"name name-special\">dissonant</span> worlds",
    "SimplifiedChinese": "收集在战斗中倒下的<span class=\"name name-special\">腐化护卫</span>掉落的容器<br>可以通过<span class=\"name name-special\">不谐</span>世界中的紫色水晶收集",
    "TraditionalChinese": "從<span class=\"name name-special\">受腐蝕巡警</span>被擊敗時掉落的桶罐採收<br>可以從<span class=\"name name-special\">不和諧</span>世界的紫色水晶收集"
  },
  "PinObjectiveScannableType": "CorruptedCrystal",
