  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Frost Crystals</span> are harvested from the leaves of <span class=\"name name-tradeable\">Frostwort</span>.<br>The host plant grows wild in a <span class=\"name name-technology\">frozen climate</span>, but can be farmed in all environments with the aid of a <span class=\"name name-technology\">Hydroponics Tray</span>.",
    "SimplifiedChinese": "<span class=\"name name-technology\">冰霜结晶</span>能从<span class=\"name name-tradeable\">冰霜花</span>上的树叶中采集到。<br>其宿主植物需要在<span class=\"name name-technology\">冰冻气候</span>下才能旺盛生长，但如果在<span class=\"name name-technology\">水培盘</span>中培养，则可以在任何环境中生存。",
    "TencentChinese": "<span class=\"name name-technology\">冰霜结晶</span>能从<span class=\"name name-tradeable\">冰霜花</span>上的树叶中采集到。<br>其宿主植物需要在<span class=\"name name-technology\">冰冻气候</span>下才能旺盛生长，但如果在<span class=\"name name-technology\">水培盘</span>中培养，则可以在任何环境中生存。",
    "TraditionalChinese": "<span class=\"name name-technology\">霜晶</span>是從<span class=\"name name-tradeable\">霜草</span>葉子採收而來。<br>宿主植物野生生長於<span class=\"name name-technology\">冰寒氣候</span>，但若借助<span class=\"name name-technology\">水耕盤</span>，便能在任何環境中栽種。"
  },
  "PinObjectiveMessage": {
    "English": "Harvest from the leaves of <span class=\"name name-tradeable\">Frostwort</span>, which grows wild in a <span class=\"name name-technology\">frozen climate</span><br>This plant can be farmed within a <span class=\"name name-commodity\">base</span> with the aid of an <span class=\"name name-tradeable\">Agricultural Specialist</span>",
    "SimplifiedChinese": "采集自<span class=\"name name-technology\">冰冻气候</span>中的野生<span class=\"name name-tradeable\">霜草</span>叶片<br>可以在<span class=\"name name-commodity\">农业专家</span>的帮助下于<span class=\"name name-tradeable\">基地</span>中种植这种植物",
    "TraditionalChinese": "採收自<span class=\"name name-tradeable\">霜草</span>的葉片，其生長於<span class=\"name name-technology\">冰寒氣候</span>的野生環境<br>借助<span class=\"name name-tradeable\">農業專家</span>的力量即可在<span class=\"name name-commodity\">基地</span>種植這種植物"
  },
