    "TraditionalChinese": "加工氡"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Radon</span> is a colorless, odorless <span class=\"name name-tradeable\">gas</span> with a relatively short half-life. <br>With the aid of an <span class=\"name name-technology\">Atmosphere Harvester</span>, can be extracted from the atmospheres of <span class=\"name name-commodity\">Radioactive</span> and <span class=\"name name-technology\">Frozen</span> planets.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">氡</span>是一种无色无味的<span class=\"name name-tradeable\">气体</span>，其半衰期相对较短。<br>可以使用<span class=\"name name-technology\">大气采集器</span>，从<span class=\"name name-commodity\">辐射</span>和<span class=\"name name-technology\">冰冻</span>星球上的大气中将气体提取出来。",
    "TencentChinese": "<span class=\"name name-tradeable\">氡</span>是一种无色无味的<span class=\"name name-tradeable\">气体</span>，其半衰期相对较短。<br>可以使用<span class=\"name name-technology\">大气采集器</span>，从<span class=\"name name-commodity\">辐射</span>和<span class=\"name name-technology\">冰冻</span>星球上的大气中将气体提取出来。",
    "TraditionalChinese": "<span class=\"name name-tradeable\">氡</span>是無色無味的<span class=\"name name-tradeable\">氣體</span>半衰期相對較短。<br>若借助<span class=\"name name-technology\">大氣採集器</span>，可從<span class=\"name name-commodity\">輻射</span>和<span class=\"name name-technology\">結冰</span>星球的大氣層中萃取到。"
  },
  "PinObjectiveMessage": {
    "English": "Deploy an <span class=\"name name-technology\">Atmosphere Harvester</span> on <span class=\"name name-commodity\">radioactive</span> or <span class=\"name name-technology\">frozen</span> worlds",
    "SimplifiedChinese": "在<span class=\"name name-commodity\">放射性</span>或<span class=\"name name-technology\">冰冻</span>星球部署一台<span class=\"name name-technology\">大气收集器</span>",
    "TraditionalChinese": "在<span class=\"name name-commodity\">輻射</span>或<span class=\"name name-technology\">冰寒</span>世界部署<span class=\"name name-technology\">大氣採集器</span>"
  },
