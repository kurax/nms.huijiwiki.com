  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-stellar\">Cadmium</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span>.<br>Find cadmium deposits with the <span class=\"name name-technology\">Analysis Visor</span>. Cadmium deposits are found on planets orbiting <span class=\"name name-fuel\">red stars</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">地形操纵器</span>从大型矿床中开采<span class=\"name name-stellar\">镉</span><br>使用<span class=\"name name-technology\">分析面甲</span>寻找镉矿。镉矿可以在围绕<span class=\"name name-fuel\">红色恒星</span>运行的行星上找到。",
    "TencentChinese": "使用<span class=\"name name-technology\">地形操纵器</span>从大型矿床中开采<span class=\"name name-stellar\">镉</span><br>使用<span class=\"name name-technology\">分析面甲</span>寻找镉矿。镉矿可以在围绕<span class=\"name name-fuel\">红色恒星</span>运行的行星上找到。",
    "TraditionalChinese": "<span class=\"name name-stellar\">鎘</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>用<span class=\"name name-technology\">分析護目鏡</span>找出鎘礦資源產地。在環繞<span class=\"name name-fuel\">紅色恆星</span>的行星上可找到鎘礦資源產地。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-stellar\">Cadmium</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span><br>Find cadmium deposits with the <span class=\"name name-technology\">Analysis Visor</span> on planets orbiting <span class=\"name name-fuel\">red stars</span>",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">地形操纵器</span>开采大型资源点中的<span class=\"name name-stellar\">镉</span><br>在环绕<span class=\"name name-fuel\">红色恒星</span>的星球上使用<span class=\"name name-technology\">分析面甲</span>寻找镉资源点",
    "TraditionalChinese": "<span class=\"name name-stellar\">鎘</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>在環繞<span class=\"name name-fuel\">紅色恆星</span>的行星上，使用<span class=\"name name-technology\">分析護目鏡</span>找出鎘礦資源產地"
  },
