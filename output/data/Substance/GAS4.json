  "PinObjective": {
    "English": "Process Methane",
    "SimplifiedChinese": "处理甲烷",
    "TencentChinese": "处理甲烷",
    "TraditionalChinese": "加工甲烷"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Methane</span> is a hazardous <span class=\"name name-tradeable\">gas</span> found in the stormy atmosphere of a <span class=\"name name-special\">gas giant</span>.<br><br>With the aid of an <span class=\"name name-technology\">Atmosphere Harvester</span>, can be extracted from the furious clouds that blanket these worlds.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">甲烷</span>是一种能够在<span class=\"name name-special\">气态巨星</span>的风暴环境中找到的危险<span class=\"name name-tradeable\">气体</span>。<br><br>借助<span class=\"name name-technology\">大气收集器</span>从笼罩气体世界的汹涌云团中采集甲烷。",
    "TraditionalChinese": "<span class=\"name name-tradeable\">甲烷</span>是<span class=\"name name-special\">氣態巨行星</span>狂暴大氣中可見的危險<span class=\"name name-tradeable\">氣體</span>。<br><br>若借助<span class=\"name name-technology\">大氣採集器</span>，可從覆蓋這些世界的洶湧雲層中採集。"
  },
  "PinObjectiveMessage": {
    "English": "Deploy an <span class=\"name name-technology\">Atmosphere Harvester</span> on a <span class=\"name name-special\">gas giant</span>",
    "SimplifiedChinese": "在一颗<span class=\"name name-special\">气态巨星</span>上部署<span class=\"name name-technology\">大气收集器</span>",
    "TraditionalChinese": "在<span class=\"name name-special\">氣態巨行星</span>部署<span class=\"name name-technology\">大氣採集器</span>"
  },
