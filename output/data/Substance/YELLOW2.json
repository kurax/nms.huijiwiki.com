  "PinObjective": {
    "English": "Gather Copper",
    "SimplifiedChinese": "收集铜",
    "TencentChinese": "收集铜",
    "TraditionalChinese": "收集銅"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-stellar\">Copper</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span>.<br>Find copper deposits with the <span class=\"name name-technology\">Analysis Visor</span>. Copper deposits are found on planets orbiting <span class=\"name name-stellar\">yellow stars</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">地形操纵器</span>从大型矿床中开采铜<br>使用<span class=\"name name-technology\">分析面甲</span>寻找铜矿。铜矿可以在围绕<span class=\"name name-stellar\">黄色恒星</span>运行的行星上找到。",
    "TencentChinese": "使用<span class=\"name name-technology\">地形操纵器</span>从大型矿床中开采铜<br>使用<span class=\"name name-technology\">分析面甲</span>寻找铜矿。铜矿可以在围绕<span class=\"name name-stellar\">黄色恒星</span>运行的行星上找到。",
    "TraditionalChinese": "<span class=\"name name-stellar\">銅</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>用<span class=\"name name-technology\">分析護目鏡</span>找出銅礦資源產地。在環繞<span class=\"name name-stellar\">黃色恆星</span>的行星上可找到銅礦資源產地。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-stellar\">Copper</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span><br>Find copper deposits with the <span class=\"name name-technology\">Analysis Visor</span>",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">地形操纵器</span>开采大型资源点中的<span class=\"name name-stellar\">铜</span><br>使用<span class=\"name name-technology\">分析面甲</span>寻找铜资源点",
    "TraditionalChinese": "<span class=\"name name-stellar\">銅</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>使用<span class=\"name name-technology\">分析護目鏡</span>找出銅礦資源產地"
  },
