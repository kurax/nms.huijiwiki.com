  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-stellar\">Indium</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span>.<br>Find indium deposits with the <span class=\"name name-technology\">Analysis Visor</span>. Indium deposits are found on planets orbiting <span class=\"name name-technology\">blue stars</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">地形操纵器</span>从大型矿床中开采<span class=\"name name-stellar\">铟</span><br>使用<span class=\"name name-technology\">分析面甲</span>寻找铟矿。铟矿可以在围绕<span class=\"name name-technology\">蓝色恒星</span>运行的行星上找到。",
    "TencentChinese": "使用<span class=\"name name-technology\">地形操纵器</span>从大型矿床中开采<span class=\"name name-stellar\">铟</span><br>使用<span class=\"name name-technology\">分析面甲</span>寻找铟矿。铟矿可以在围绕<span class=\"name name-technology\">蓝色恒星</span>运行的行星上找到。",
    "TraditionalChinese": "<span class=\"name name-stellar\">銦</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>用<span class=\"name name-technology\">分析護目鏡</span>找出銦礦資源產地。在環繞<span class=\"name name-technology\">藍色恆星</span>的行星上可找到銦礦資源產地。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-stellar\">Indium</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span><br>Find indium deposits with the <span class=\"name name-technology\">Analysis Visor</span> on planets orbiting <span class=\"name name-technology\">blue stars</span>",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">地形操纵器</span>开采大型资源点中的<span class=\"name name-stellar\">铟</span><br>在环绕<span class=\"name name-technology\">蓝色恒星</span>的星球上使用<span class=\"name name-technology\">分析面甲</span>寻找铟资源点",
    "TraditionalChinese": "<span class=\"name name-stellar\">銦</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>在環繞<span class=\"name name-technology\">藍色恆星</span>的行星上，使用<span class=\"name name-technology\">分析護目鏡</span>找出銦礦資源產地"
  },
