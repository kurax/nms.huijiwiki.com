  "PinObjectiveTip": {
    "English": "<span class=\"name name-stellar\">Ancestral Memories</span> are echoes of genetic possibilities, forgotten by evolution.<br><br>Harvest <span class=\"name name-stellar\">Ancestral Memories</span> from friendly creatures caught within the loop. Befriend creatures by feeding them Creature Pellets.",
    "SimplifiedChinese": "<span class=\"name name-stellar\">先祖记忆</span>是一种潜在基因的回音，被进化所遗忘。<br><br>从被循环捕获的友好生物中提取<span class=\"name name-stellar\">先祖记忆</span>。给动物喂生物颗粒从而与它们变得亲近友好。",
    "TraditionalChinese": "<span class=\"name name-stellar\">祖傳記憶</span>為被演化所遺忘的基因可能性回音。<br><br>你可從受困於迴圈的友善生物上採收<span class=\"name name-stellar\">祖傳記憶</span>。透過餵食生物顆粒飼料即可與生物交朋友。"
  },
  "PinObjectiveMessage": {
    "English": "Harvest <span class=\"name name-stellar\">Ancestral Memories</span> from friendly creatures caught within the loop",
    "SimplifiedChinese": "从陷入循环的友好生物身上采集<span class=\"name name-stellar\">先祖记忆</span>",
