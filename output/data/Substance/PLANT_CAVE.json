  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Marrow Bulbs</span> are harvested from the <span class=\"name name-tradeable\">Cave Marrow plant</span> found growing <span class=\"name name-technology\">underground</span>.<br>Locate natural cave entrances or create your own with the <span class=\"name name-technology\">Terrain Manipulator</span>. <span class=\"name name-red\">WARNING:</span> many caves contain hazardous flora.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">葫芦朵</span>能从<span class=\"name name-technology\">地下生长的</span><span class=\"name name-tradeable\">洞穴葫芦属植物</span>上采集到。<br>寻找天然洞穴的入口，或使用<span class=\"name name-technology\">地形操纵器</span>自己创造出洞穴。<span class=\"name name-red\">警告：</span>许多洞穴中存在危险的植物群系。",
    "TencentChinese": "<span class=\"name name-tradeable\">葫芦朵</span>能从<span class=\"name name-technology\">地下生长的</span><span class=\"name name-tradeable\">洞穴葫芦属植物</span>上采集到。<br>寻找天然洞穴的入口，或使用<span class=\"name name-technology\">地形操纵器</span>自己创造出洞穴。<span class=\"name name-red\">警告：</span>许多洞穴中存在危险的植物群系。",
    "TraditionalChinese": "<span class=\"name name-tradeable\">葫蘆莖</span>是從長在<span class=\"name name-technology\">地底下</span>的<span class=\"name name-tradeable\">洞窟葫蘆植物</span>採收而來。<br>使用<span class=\"name name-technology\">地形改造器</span>找出天然洞穴入口或自行製造一個。<span class=\"name name-red\">警告：</span>許多洞穴內有危險植物。"
  },
  "PinObjectiveMessage": {
    "English": "Harvest from the <span class=\"name name-tradeable\">Cave Marrow plant</span> found growing <span class=\"name name-technology\">underground</span><br>This plant can be farmed within a <span class=\"name name-commodity\">base</span> with the aid of an <span class=\"name name-tradeable\">Agricultural Specialist</span>",
    "SimplifiedChinese": "采集自<span class=\"name name-technology\">地下</span>生长的<span class=\"name name-tradeable\">洞穴葫芦</span><br>可以在<span class=\"name name-commodity\">农业专家</span>的帮助下于<span class=\"name name-tradeable\">基地</span>中种植这种植物",
    "TraditionalChinese": "採收自生長在<span class=\"name name-technology\">地底下</span>的<span class=\"name name-tradeable\">洞窟葫蘆植物</span><br>借助<span class=\"name name-tradeable\">農業專家</span>的力量即可在<span class=\"name name-commodity\">基地</span>種植這種植物"
  },
