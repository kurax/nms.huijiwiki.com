  "PinObjective": {
    "English": "Gather Quartzite",
    "SimplifiedChinese": "收集石英岩",
    "TencentChinese": "收集石英岩",
    "TraditionalChinese": "收集石英岩"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-stellar\">Quartzite</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span>.<br>Find quartzite deposits with the <span class=\"name name-technology\">Analysis Visor</span>. Quartzite deposits are found on planets orbiting <span class=\"name name-special\">purple stars</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-stellar\">地形操纵器</span>从大型资源点中开采<span class=\"name name-technology\">石英岩</span>。<br>使用<span class=\"name name-technology\">分析面甲</span>寻找石英岩资源点。石英岩资源点可以在围绕<span class=\"name name-special\">紫色恒星</span>运行的行星上找到。",
    "TraditionalChinese": "<span class=\"name name-stellar\">石英岩</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>使用<span class=\"name name-technology\">分析護目鏡</span>找出石英岩礦資源產地。在環繞<span class=\"name name-special\">紫色恆星</span>的行星上可找到石英岩礦資源產地。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-stellar\">Quartzite</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span><br>Find quartzite deposits with the <span class=\"name name-technology\">Analysis Visor</span> on planets orbiting <span class=\"name name-special\">purple stars</span>",
    "SimplifiedChinese": "使用<span class=\"name name-stellar\">地形操纵器</span>从大型资源点中开采<span class=\"name name-technology\">石英岩</span>。<br>在围绕<span class=\"name name-technology\">紫色恒星</span>运行的星球上使用<span class=\"name name-special\">分析面甲</span>寻找石英岩资源点",
    "TraditionalChinese": "<span class=\"name name-stellar\">石英岩</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>在環繞<span class=\"name name-special\">紫色恆星</span>的行星上，使用<span class=\"name name-technology\">分析護目鏡</span>找出石英岩礦資源產地"
  },
