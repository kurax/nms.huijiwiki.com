  "PinObjective": {
    "English": "Gather Tritium",
    "SimplifiedChinese": "收集氚",
    "TencentChinese": "收集氚",
    "TraditionalChinese": "收集氚"
  },
  "PinObjectiveTip": {
    "English": "<VAL_ON>Tritium<> is abundant in asteroid fields. Find asteroid fields in rings around planets or at intervals in interstellar flight. Scan (<span class=\"name name-img\">SCAN</span>) to search for <span class=\"name name-technology\">tritium-rich asteroids</span>.",
    "SimplifiedChinese": "<VAL_ON>氚<>在小行星区域内很丰富。在行星环中，或在星际飞行的中途寻找小行星区域。扫描（<span class=\"name name-img\">SCAN</span>）以搜寻<span class=\"name name-technology\">富含氚的小行星</span>。",
    "TencentChinese": "<VAL_ON>氚<>在小行星区域内很丰富。在行星环中，或在星际飞行的中途寻找小行星区域。",
    "TraditionalChinese": "小行星帶內有大量的<VAL_ON>氚<>。從圍繞著星球的行星環或於星際飛航之間找出小行星帶。掃描 (<span class=\"name name-img\">SCAN</span>) 即可找尋<span class=\"name name-technology\">富含氚的小行星</span>。"
  },
  "PinObjectiveMessage": {
    "English": "<VAL_ON>Tritium<> is abundant in asteroid fields<br>In space, scan (<span class=\"name name-img\">SCAN</span>) to search for <span class=\"name name-technology\">tritium-rich asteroids</span>",
    "SimplifiedChinese": "小行星带中富含<VAL_ON>氚<><br>在太空中时，使用扫描（<span class=\"name name-img\">SCAN</span>）寻找<span class=\"name name-technology\">富含氚的小行星</span>",
    "TraditionalChinese": "小行星帶內有大量的<VAL_ON>氚<><br>在太空中，掃描 (<span class=\"name name-img\">SCAN</span>) 即可找出<span class=\"name name-technology\">富含氚的小行星</span>"
  },
