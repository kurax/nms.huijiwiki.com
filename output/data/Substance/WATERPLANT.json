  "PinObjective": {
    "English": "Refine Cyto-Phosphate",
    "SimplifiedChinese": "精炼磷酸细胞",
    "TencentChinese": "精炼磷酸细胞",
    "TraditionalChinese": "精製細胞磷酸鹽"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Cyto-Phosphates</span> are readily extracted from <span class=\"name name-earth\">underwater plants</span>.<br>Increase marine efficiency by upgrading the Exosuit <span class=\"name name-technology\">Aeration Membrane</span>, refilling oxygen supplies from <span class=\"name name-tradeable\">Kelp Sacs</span>, or travelling in a <span class=\"name name-stellar\">Nautilon Submarine</span>.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">磷酸细胞</span>能从<span class=\"name name-earth\">水下植物</span>中轻易提取而得。<br>升级套装的<span class=\"name name-technology\">曝气膜</span>，从<span class=\"name name-tradeable\">海藻袋</span>中补充氧气补给，或搭乘<span class=\"name name-stellar\">大鹦鹉螺潜水艇</span>出行，以提高在海洋中的效率。",
    "TencentChinese": "<span class=\"name name-tradeable\">磷酸细胞</span>能从<span class=\"name name-earth\">水下植物</span>中轻易提取而得。<br>升级套装的<span class=\"name name-technology\">曝气膜</span>，从<span class=\"name name-tradeable\">海藻袋</span>中补充氧气补给，或搭乘<span class=\"name name-stellar\">大鹦鹉螺潜水艇</span>出行，以提高在海洋中的效率。",
    "TraditionalChinese": "穩定地從<span class=\"name name-earth\">海底植物</span>萃取<span class=\"name name-tradeable\">細胞磷酸鹽</span>。<br>升級強化套裝的<span class=\"name name-technology\">曝氣黏膜</span>以增加海中效率，從<span class=\"name name-tradeable\">巨藻囊</span>補充氧氣補給品，或搭乘<span class=\"name name-stellar\">巡洋龍潛艇</span>前進。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-tradeable\">Cyto-Phosphates</span> are extracted from <span class=\"name name-earth\">underwater plants</span>",
    "SimplifiedChinese": "从<span class=\"name name-earth\">水下植物</span>提取<span class=\"name name-tradeable\">磷酸细胞</span>",
    "TraditionalChinese": "<span class=\"name name-tradeable\">細胞磷酸鹽</span>可從<span class=\"name name-earth\">水下植物</span>採集"
  },
