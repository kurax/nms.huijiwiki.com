  "PinObjective": {
    "English": "Gather or refine Platinum",
    "SimplifiedChinese": "收集或精炼铂",
    "TencentChinese": "收集或精炼铂",
    "TraditionalChinese": "收集或精製鉑"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-earth\">Platinum</span> is a rare interstellar trading mineral, <span class=\"name name-commodity\">mined from asteroids</span>. Very occasionally found in underground planetary deposits.",
    "SimplifiedChinese": "<span class=\"name name-earth\">铂</span>是一种宝贵的星际贸易矿物质，通常<span class=\"name name-commodity\">从小行星开采</span>得到。有时可在行星地下矿床中发现。",
    "TencentChinese": "<span class=\"name name-earth\">铂</span>是一种宝贵的星际贸易矿物质，通常<span class=\"name name-commodity\">从小行星开采</span>得到。有时可在行星地下矿床中发现。",
    "TraditionalChinese": "<span class=\"name name-earth\">鉑</span>是罕見的星際交易礦物，<span class=\"name name-commodity\">從小行星開採而來</span>。偶爾才會在星球地底資源產地找到。"
  },
  "PinObjectiveMessage": {
    "English": "Mine platinum from <span class=\"name name-commodity\">asteroids</span> while piloting the starship (<span class=\"name name-img\">SHIPFIRE</span>)<br>Platinum is rare in most asteroid fields",
    "SimplifiedChinese": "驾驶飞船（<span class=\"name name-img\">SHIPFIRE</span>）开采<span class=\"name name-commodity\">小行星</span>中的铂<br>铂在绝大多数小行星带中都很稀有",
    "TraditionalChinese": "駕駛太空船 (<span class=\"name name-img\">SHIPFIRE</span>)，從<span class=\"name name-commodity\">小行星</span>開採鉑礦 <br>鉑礦在大部分的小行星帶中都相當罕見"
  },
