  "PinObjective": {
    "English": "Gather Fungal Mold",
    "SimplifiedChinese": "收集真菌霉",
    "TencentChinese": "收集真菌霉",
    "TraditionalChinese": "收集蕈模"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Fungal Mould</span> is harvested from the gills of <span class=\"name name-tradeable\">Fungal Clusters</span>.<br>The host plant grows wild in a <span class=\"name name-tradeable\">toxic climate</span>, but can be farmed in all environments with the aid of a <span class=\"name name-technology\">Hydroponics Tray</span>.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">真菌霉</span>能从<span class=\"name name-tradeable\">真菌团</span>的菌褶中采集到。<br>其宿主植物需要在<span class=\"name name-tradeable\">毒性气候</span>下才能旺盛生长，但如果在<span class=\"name name-technology\">水培盘</span>中培养，则可以在任何环境中生存。",
    "TencentChinese": "<span class=\"name name-tradeable\">真菌霉</span>能从<span class=\"name name-tradeable\">真菌团</span>的菌褶中采集到。<br>其宿主植物需要在<span class=\"name name-tradeable\">毒性气候</span>下才能旺盛生长，但如果在<span class=\"name name-technology\">水培盘</span>中培养，则可以在任何环境中生存。",
    "TraditionalChinese": "<span class=\"name name-tradeable\">蕈模</span>是從<span class=\"name name-tradeable\">蕈群</span>菌褶上採收而來。<br>宿主植物野生生長於<span class=\"name name-tradeable\">有毒氣候</span>，但若借助<span class=\"name name-technology\">水耕盤</span>，便能在任何環境中栽種。"
  },
  "PinObjectiveMessage": {
    "English": "Harvest from the gills of <span class=\"name name-tradeable\">Fungal Clusters</span>, which grows wild in a <span class=\"name name-tradeable\">toxic climate</span><br>This plant can be farmed within a <span class=\"name name-commodity\">base</span> with the aid of an <span class=\"name name-tradeable\">Agricultural Specialist</span>",
    "SimplifiedChinese": "采集自<span class=\"name name-tradeable\">毒性气候</span>中的野生<span class=\"name name-tradeable\">真菌团</span>菌褶<br>可以在<span class=\"name name-commodity\">农业专家</span>的帮助下于<span class=\"name name-tradeable\">基地</span>中种植这种植物",
    "TraditionalChinese": "採收自<span class=\"name name-tradeable\">蕈群</span>的菌褶，其生長於<span class=\"name name-tradeable\">劇毒氣候</span>的野生環境<br>借助<span class=\"name name-tradeable\">農業專家</span>的力量即可在<span class=\"name name-commodity\">基地</span>種植這種植物"
  },
  "PinObjectiveScannableType": "HarvestPlant",
