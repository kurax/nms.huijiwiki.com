  "PinObjective": {
    "English": "Gather Pugneum",
    "SimplifiedChinese": "收集普茵",
    "TencentChinese": "收集普茵",
    "TraditionalChinese": "收集搏"
  },
  "PinObjectiveTip": {
    "English": "A dark, liquid glass, <span class=\"name name-special\">Pugneum</span> is extracted from the remains of <span class=\"name name-special\">Sentinels</span>. Engage Sentinel forces in combat to release Pugneum from their shells.",
    "SimplifiedChinese": "<span class=\"name name-special\">普茵</span>是一种深色的液态玻璃体，是从<span class=\"name name-special\">护卫</span>的遗体上提取出来的。与护卫战斗，将普茵从他们的外壳中释放出来。",
    "TencentChinese": "<span class=\"name name-special\">普茵</span>是一种深色的液态玻璃体，是从<span class=\"name name-special\">护卫</span>的遗体上提取出来的。与护卫战斗，将普茵从他们的外壳中释放出来。",
    "TraditionalChinese": "深色的液體玻璃<span class=\"name name-special\">搏</span>萃取自<span class=\"name name-special\">巡警</span>的殘骸。 與巡警方展開戰鬥將其殼體中搏釋放出來。"
  },
  "PinObjectiveMessage": {
    "English": "A dark, liquid glass, <span class=\"name name-special\">Pugneum</span> is extracted from the remains of <span class=\"name name-special\">Sentinels</span>.<br>Engage Sentinel forces in combat to release Pugneum from their shells.",
    "SimplifiedChinese": "<span class=\"name name-special\">普茵</span>是一种深色的液态玻璃体，是从<span class=\"name name-special\">护卫</span>的遗体上提取出来的。<br>与护卫部队战斗，将普茵从他们的外壳中释放出来。",
    "TraditionalChinese": "<span class=\"name name-special\">搏</span>元素是一種深色的液態玻璃，其萃取自<span class=\"name name-special\">巡警</span>的殘骸。<br>與巡警部隊搏鬥，並從其外殼中取出搏元素。"
  },
