  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Cactus Flesh</span> is harvested from the flesh of the <span class=\"name name-tradeable\">Echinocactus plant</span><br>The host plant grows wild in a <span class=\"name name-stellar\">barren climate</span>, but can be farmed in all environments with the aid of a <span class=\"name name-technology\">Hydroponics Tray</span>.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">仙人掌肉</span>能从<span class=\"name name-tradeable\">金琥植物</span>上的叶肉中采集到。<br>其宿主植物需要在<span class=\"name name-stellar\">贫瘠气候</span>下才能旺盛生长，但如果在<span class=\"name name-technology\">水培盘</span>中培养，则可以在任何环境中生存。",
    "TencentChinese": "<span class=\"name name-tradeable\">仙人掌肉</span>能从<span class=\"name name-tradeable\">金琥植物</span>上的叶肉中采集到。<br>其宿主植物需要在<span class=\"name name-stellar\">贫瘠气候</span>下才能旺盛生长，但如果在<span class=\"name name-technology\">水培盘</span>中培养，则可以在任何环境中生存。",
    "TraditionalChinese": "<span class=\"name name-tradeable\">仙人掌肉</span>是從<span class=\"name name-tradeable\">仙人球植物</span>果肉採收而來。<br>宿主植物野生生長於<span class=\"name name-stellar\">荒蕪氣候</span>，但若借助<span class=\"name name-technology\">水耕盤</span>，便能在任何環境中栽種。"
  },
  "PinObjectiveMessage": {
    "English": "Harvest from the flesh of the <span class=\"name name-tradeable\">Echinocactus plant</span>, which grows wild in a <span class=\"name name-stellar\">barren climate</span><br>This plant can be farmed within a <span class=\"name name-commodity\">base</span> with the aid of an <span class=\"name name-tradeable\">Agricultural Specialist</span>",
    "SimplifiedChinese": "采集自<span class=\"name name-stellar\">贫瘠气候</span>中的野生<span class=\"name name-tradeable\">金琥</span>肉质<br>可以在<span class=\"name name-commodity\">农业专家</span>的帮助下于<span class=\"name name-tradeable\">基地</span>中种植这种植物",
    "TraditionalChinese": "採收自<span class=\"name name-tradeable\">仙人球植物</span>的果肉，其生長於<span class=\"name name-stellar\">荒蕪氣候</span>的野生環境<br>借助<span class=\"name name-tradeable\">農業專家</span>的力量即可在<span class=\"name name-commodity\">基地</span>種植這種植物"
  },
