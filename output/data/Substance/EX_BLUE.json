  "PinObjectiveTip": {
    "English": "<span class=\"name name-stellar\">Activated Indium</span> is created by the harsh environmental conditions on <span class=\"name name-fuel\">Extreme Weather Planets</span>.<br>Find indium deposits with the <span class=\"name name-technology\">Analysis Visor</span> and mine using the <span class=\"name name-technology\">Terrain Manipulator</span>. Indium deposits are found on planets orbiting <span class=\"name name-technology\">blue stars</span>.",
    "SimplifiedChinese": "<span class=\"name name-stellar\">活性铟</span>是在<span class=\"name name-fuel\">极端气候星球</span>上的恶劣环境条件下产生的。<br>使用<span class=\"name name-technology\">分析面甲</span>找到铟矿并使用<span class=\"name name-technology\">地形操纵器</span>采矿。铟矿可以在围绕<span class=\"name name-stellar\">蓝色恒星</span>运行的行星上找到。",
    "TencentChinese": "<span class=\"name name-stellar\">活性铟</span>是在<span class=\"name name-fuel\">极端气候星球</span>上的恶劣环境条件下产生的。<br>使用<span class=\"name name-technology\">分析面甲</span>找到铟矿并使用<span class=\"name name-technology\">地形操纵器</span>采矿。铟矿可以在围绕<span class=\"name name-stellar\">蓝色恒星</span>运行的行星上找到。",
    "TraditionalChinese": "<span class=\"name name-stellar\">活性銦</span>是由<span class=\"name name-fuel\">極端氣候星球</span>上的殘酷環境條件所造成的。<br>用<span class=\"name name-technology\">分析護目鏡</span>找出銦資源產地，並使用<span class=\"name name-technology\">地形改造器</span>開採。在環繞<span class=\"name name-technology\">藍色恆星</span>的行星上可找到銦資源產地。"
  },
  "PinObjectiveMessage": {
    "English": "Activated Indium is mined from large deposits on <span class=\"name name-fuel\">extreme weather</span> worlds that orbit <span class=\"name name-technology\">blue</span> stars<br>Find activated deposits with the <span class=\"name name-technology\">Analysis Visor</span> and extract with the <span class=\"name name-technology\">Terrain Manipulator</span>",
    "SimplifiedChinese": "在环绕<span class=\"name name-technology\">蓝色</span>恒星的<span class=\"name name-fuel\">极端天气</span>星球中寻找大型资源点并开采活性铟<br>使用<span class=\"name name-technology\">分析面甲</span>寻找活性资源点，然后使用<span class=\"name name-technology\">地形操纵器</span>提取资源",
    "TraditionalChinese": "活性銦蘊藏於環繞<span class=\"name name-technology\">藍色</span>恆星的<span class=\"name name-fuel\">極端天氣</span>世界，是從大型資源產地採集而來<br>使用<span class=\"name name-technology\">分析護目鏡</span>找出活性礦資源產地，並使用<span class=\"name name-technology\">地形改造器</span>採集"
  },
