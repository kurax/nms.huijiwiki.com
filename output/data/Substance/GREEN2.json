  "PinObjective": {
    "English": "Gather Emeril",
    "SimplifiedChinese": "收集艾梅里尔",
    "TencentChinese": "收集艾梅里尔",
    "TraditionalChinese": "收集砪"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-stellar\">Emeril</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span>.<br>Find emeril deposits with the <span class=\"name name-technology\">Analysis Visor</span>. Emeril deposits are found on planets orbiting <span class=\"name name-tradeable\">green stars</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">地形操纵器</span>从大型矿床中开采<span class=\"name name-stellar\">艾梅里尔</span><br>使用<span class=\"name name-technology\">分析面甲</span>寻找艾梅里尔矿。艾梅里尔矿可以在围绕<span class=\"name name-tradeable\">绿色恒星</span>运行的行星上找到。",
    "TencentChinese": "使用<span class=\"name name-technology\">地形操纵器</span>从大型矿床中开采<span class=\"name name-stellar\">艾梅里尔</span><br>使用<span class=\"name name-technology\">分析面甲</span>寻找艾梅里尔矿。艾梅里尔矿可以在围绕<span class=\"name name-tradeable\">绿色恒星</span>运行的行星上找到。",
    "TraditionalChinese": "<span class=\"name name-stellar\">砪</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>用<span class=\"name name-technology\">分析護目鏡</span>找出砪礦資源產地。在環繞<span class=\"name name-tradeable\">綠色恆星</span>的行星上可找到砪礦資源產地。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-stellar\">Emeril</span> is mined from large deposits using the <span class=\"name name-technology\">Terrain Manipulator</span><br>Find emeril deposits with the <span class=\"name name-technology\">Analysis Visor</span> on planets orbiting <span class=\"name name-tradeable\">green stars</span>",
    "SimplifiedChinese": "使用<span class=\"name name-technology\">地形操纵器</span>开采大型资源点中的<span class=\"name name-stellar\">艾梅里尔</span><br>在环绕<span class=\"name name-tradeable\">绿色恒星</span>的星球上使用<span class=\"name name-technology\">分析面甲</span>寻找艾梅里尔资源点",
    "TraditionalChinese": "<span class=\"name name-stellar\">砪</span>是使用<span class=\"name name-technology\">地形改造器</span>從大型資源產地開採出來的。<br>在環繞<span class=\"name name-tradeable\">綠色恆星</span>的行星上，使用<span class=\"name name-technology\">分析護目鏡</span>找出砪礦資源產地"
  },
