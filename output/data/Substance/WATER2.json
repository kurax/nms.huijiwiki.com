  "PinObjective": {
    "English": "Refine Chlorine",
    "SimplifiedChinese": "精炼氯",
    "TencentChinese": "精炼氯",
    "TraditionalChinese": "精製氯"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Chlorine</span> is created from Salt in a <span class=\"name name-technology\">Refiner</span>.<br>Chlorine can be mined directly from large underwater deposits. Mining requires use of an <span class=\"name name-technology\">Advanced Mining Laser</span>.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">氯</span>可采用<span class=\"name name-technology\">精炼机</span>从盐中制得。<br>氯可以直接从大型水下矿床中开采。开采需要使用<span class=\"name name-technology\">高级开采光束</span>。",
    "TencentChinese": "<span class=\"name name-tradeable\">氯</span>可采用<span class=\"name name-technology\">精炼机</span>从盐中制得。<br>氯可以直接从大型水下矿床中开采。开采需要使用<span class=\"name name-technology\">高级开采光束</span>。",
    "TraditionalChinese": "<span class=\"name name-tradeable\">氯</span>是以<span class=\"name name-technology\">精製機</span>從鹽萃取出來的。<br>氯可從大型水底資源產地開採出來。開採時需要用到<span class=\"name name-technology\">改良採礦雷射</span>。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-tradeable\">Chlorine</span> is created from Salt in a <span class=\"name name-technology\">Refiner</span><br>Extract <span class=\"name name-tradeable\">Salt</span> from <span class=\"name name-earth\">underwater rock deposits</span>",
    "SimplifiedChinese": "在<span class=\"name name-tradeable\">精炼机</span>中加工盐以制作<span class=\"name name-technology\">氯</span><br>从<span class=\"name name-earth\">水下岩石资源点中</span>提取<span class=\"name name-tradeable\">盐</span>",
    "TraditionalChinese": "<span class=\"name name-tradeable\">氯</span>是使用<span class=\"name name-technology\">精製機</span>加工鹽製作出來的<br>從<span class=\"name name-earth\">水下岩石資源產地</span>採集<span class=\"name name-tradeable\">鹽</span>"
  },
  "PinObjectiveScannableType": "None",
