  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Sulphurine</span> is a pungent atmospheric <span class=\"name name-tradeable\">gas</span>. High concentrations are extremely hazardous to organic life.<br>With the aid of an <span class=\"name name-technology\">Atmosphere Harvester</span>, can be extracted from the atmospheres of <span class=\"name name-fuel\">Scorched</span> and <span class=\"name name-special\">Barren</span> planets.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">硫磺</span>是一种刺鼻的大气<span class=\"name name-tradeable\">气体</span>。高浓度条件下对有机生命有剧毒。<br>可以使用<span class=\"name name-technology\">大气采集器</span>，从<span class=\"name name-fuel\">炎热</span>和<span class=\"name name-fuel\">贫瘠</span>星球上的大气中将气体提取出来。",
    "TencentChinese": "<span class=\"name name-tradeable\">硫磺</span>是一种刺鼻的大气<span class=\"name name-tradeable\">气体</span>。高浓度条件下对有机生命有剧毒。<br>可以使用<span class=\"name name-technology\">大气采集器</span>，从<span class=\"name name-fuel\">炎热</span>和<span class=\"name name-fuel\">贫瘠</span>星球上的大气中将气体提取出来。",
    "TraditionalChinese": "<span class=\"name name-tradeable\">硫氣</span>是氣味強烈的大氣<span class=\"name name-tradeable\">氣體</span>。高濃度極度有害有機生命。<br>若借助<span class=\"name name-technology\">大氣採集器</span>，可從<span class=\"name name-fuel\">焦土</span>和<span class=\"name name-special\">荒蕪</span>星球的大氣層中萃取到。"
  },
  "PinObjectiveMessage": {
