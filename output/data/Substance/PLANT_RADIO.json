  "PinObjectiveTip": {
    "English": "<span class=\"name name-tradeable\">Gamma Root</span> is harvested from the roots of the <span class=\"name name-tradeable\">Gamma Weed plant</span>.<br>The host plant grows wild in a <span class=\"name name-commodity\">radioactive climate</span>, but can be farmed in all environments with the aid of a <span class=\"name name-technology\">Hydroponics Tray</span>.",
    "SimplifiedChinese": "<span class=\"name name-tradeable\">伽马根</span>能从<span class=\"name name-tradeable\">伽马杂草植物</span>上的根部中采集到。<br>其宿主植物需要在<span class=\"name name-commodity\">辐射气候</span>下才能旺盛生长，但如果在<span class=\"name name-technology\">水培盘</span>中培养，则可以在任何环境中生存。",
    "TraditionalChinese": "<span class=\"name name-tradeable\">伽瑪根</span>是從<span class=\"name name-tradeable\">伽瑪草植物</span>的根部採收而來。<br>宿主植物野生生長於<span class=\"name name-commodity\">輻射氣候</span>，但若借助<span class=\"name name-technology\">水耕盤</span>，便能在任何環境中栽種。"
  },
  "PinObjectiveMessage": {
    "English": "Harvest from the roots of the <span class=\"name name-tradeable\">Gamma Weed plant</span>, which grows wild in a <span class=\"name name-commodity\">radioactive climate</span><br>This plant can be farmed within a <span class=\"name name-commodity\">base</span> with the aid of an <span class=\"name name-tradeable\">Agricultural Specialist</span>",
    "SimplifiedChinese": "采集自<span class=\"name name-commodity\">放射性气候</span>中的野生<span class=\"name name-tradeable\">伽马草</span>根须<br>可以在<span class=\"name name-commodity\">农业专家</span>的帮助下于<span class=\"name name-tradeable\">基地</span>中种植这种植物",
    "TraditionalChinese": "採收自<span class=\"name name-tradeable\">伽瑪草植物</span>的根部，其生長於<span class=\"name name-commodity\">輻射氣候</span>的野生環境<br>借助<span class=\"name name-tradeable\">農業專家</span>的力量即可在<span class=\"name name-commodity\">基地</span>種植這種植物"
  },
