  "PinObjective": {
    "English": "Gather Cobalt",
    "SimplifiedChinese": "收集钴",
    "TencentChinese": "收集钴",
    "TraditionalChinese": "收集鈷"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-technology\">Cobalt</span> is readily extracted from <span class=\"name name-earth\">subterranean rock deposits</span>.<br>Locate natural cave entrances. <span class=\"name name-red\">WARNING:</span> many caves contain hazardous flora.",
    "SimplifiedChinese": "从<span class=\"name name-earth\">地下岩石矿床</span>中容易提取出<span class=\"name name-technology\">钴</span>。<br>寻找天然洞穴的入口。<span class=\"name name-red\">警告：</span>许多洞穴中存在危险植物群系。",
    "TencentChinese": "从<span class=\"name name-earth\">地下岩石矿床</span>中容易提取出<span class=\"name name-technology\">钴</span>。<br>寻找天然洞穴的入口。<span class=\"name name-red\">警告：</span>许多洞穴中存在危险植物群系。",
    "TraditionalChinese": "<span class=\"name name-technology\">鈷</span>可從<span class=\"name name-earth\">地下岩石資源產地</span>輕易萃取出來。<br>找出天然洞穴入口。<span class=\"name name-red\">警告：</span>許多洞穴內有危險植物。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-technology\">Cobalt</span> is readily extracted from <span class=\"name name-earth\">subterranean rock deposits</span><br>Search the environment for cave entrances",
    "SimplifiedChinese": "从<span class=\"name name-earth\">地下岩石资源点</span>中提取<span class=\"name name-technology\">钴</span><br>搜索周遭环境中的洞穴入口",
    "TraditionalChinese": "<span class=\"name name-technology\">鈷</span>可從<span class=\"name name-earth\">地下岩石資源產地</span>輕易採集出來<br>搜尋周遭環境，找出洞穴入口"
  },
