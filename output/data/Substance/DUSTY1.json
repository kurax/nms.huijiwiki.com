  "PinObjective": {
    "English": "Gather or refine Pyrite",
    "SimplifiedChinese": "收集或精炼黄铁矿",
    "TencentChinese": "收集或精炼黄铁矿",
    "TraditionalChinese": "收集或精製黃鐵礦"
  },
  "PinObjectiveTip": {
    "English": "<span class=\"name name-earth\">Pyrite</span> is found primarily on worlds with a <span class=\"name name-fuel\">desert environment</span>. Typically found in large deposits and located with the <span class=\"name name-technology\">Analysis Visor</span>.<br>Common ferrite rocks may yield Pyrite after inspection with an <span class=\"name name-technology\">Analysis Visor</span>. Can be <span class=\"name name-technology\">refined</span> from other terrain elements.",
    "SimplifiedChinese": "<span class=\"name name-earth\">黄铁矿</span>主要出现在具有<span class=\"name name-fuel\">荒漠环境</span>的世界里。通常可在大型矿床中找到，可使用<span class=\"name name-technology\">分析面甲</span>来定位。<br>使用<span class=\"name name-technology\">分析面甲</span>检查常见铁氧体岩石，就有可能发现黄铁矿。可由其他岩层元素<span class=\"name name-technology\">精炼</span>得到。",
    "TencentChinese": "<span class=\"name name-earth\">黄铁矿</span>主要出现在具有<span class=\"name name-fuel\">荒漠环境</span>的世界里。通常可在大型矿床中找到，可使用<span class=\"name name-technology\">分析面甲</span>来定位。<br>使用<span class=\"name name-technology\">分析面甲</span>检查常见铁氧体岩石，就有可能发现黄铁矿。可由其他岩层元素<span class=\"name name-technology\">精炼</span>得到。",
    "TraditionalChinese": "<span class=\"name name-earth\">黃鐵礦</span>主要可見於<span class=\"name name-fuel\">沙漠環境</span>的世界。常見於大型資源產地，並可用<span class=\"name name-technology\">分析護目鏡</span>找到。<br>常見的鐵氧體岩石在使用<span class=\"name name-technology\">分析護目鏡</span>檢驗後可能會產出黃鐵礦。可從其他地形元素<span class=\"name name-technology\">精製</span>而成。"
  },
  "PinObjectiveMessage": {
    "English": "<span class=\"name name-earth\">Pyrite</span> is found primarily on worlds with a <span class=\"name name-fuel\">desert environment</span><br>Typically found in large deposits and located with the <span class=\"name name-technology\">Analysis Visor</span>",
    "SimplifiedChinese": "<span class=\"name name-earth\">黄铁矿</span>常见于拥有<span class=\"name name-fuel\">荒漠环境</span>的星球上<br>使用<span class=\"name name-technology\">分析面甲</span>定位遍布于大型资源点中的此类资源",
    "TraditionalChinese": "<span class=\"name name-earth\">黃鐵礦</span>主要可見於<span class=\"name name-fuel\">沙漠環境</span>的世界<br>常見於大型資源產地，可使用<span class=\"name name-technology\">分析護目鏡</span>找到"
  },
