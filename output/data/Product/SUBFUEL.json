  "PinObjectiveTip": {
    "English": "Craft Hydrothermal Fuel Cell from <span class=\"name name-tradeable\">cyto-phosphate</span>, <span class=\"name name-tradeable\">salt</span> and <span class=\"name name-fuel\">carbon</span>.<br>All these elements are readily extracted from <span class=\"name name-earth\">underwater plants</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-tradeable\">磷酸细胞</span>、<span class=\"name name-tradeable\">盐</span>以及<span class=\"name name-fuel\">碳</span>制作热液燃料电池。<br>所有材料都能够直接从<span class=\"name name-earth\">水下植物</span>提取。",
    "TencentChinese": "使用<span class=\"name name-technology\">二氢</span>和<span class=\"name name-commodity\">金属电镀</span>制作热液燃料电池<br><span class=\"name name-technology\">二氢</span>在大多数行星上以晶体形式出现。使用<span class=\"name name-technology\">扫描仪</span>（<span class=\"name name-img\">SCAN</span>）定位二氢晶体。<br>金属电镀由<span class=\"name name-earth\">铁氧体粉末</span>制作而成。使用<span class=\"name name-img\">PRODMENU</span>在空置<span class=\"name name-technology\">栏位</span>中制作。",
    "TraditionalChinese": "使用<span class=\"name name-tradeable\">細胞磷酸鹽</span>、<span class=\"name name-tradeable\">鹽</span>和<span class=\"name name-fuel\">碳</span>製作 熱液燃料電池。<br>以上元素可直接從<span class=\"name name-earth\">水下植物</span>取得。"
  },
