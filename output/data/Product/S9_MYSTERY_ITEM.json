{
  "_Table": "Product",
  "ID": "S9_MYSTERY_ITEM",
  "Name": {
    "English": "CONSTRUCTION HISTORY",
    "SimplifiedChinese": "建造历史",
    "TraditionalChinese": "建築歷史"
  },
  "NameLower": {
    "English": "Construction History",
    "SimplifiedChinese": "建造历史",
    "TraditionalChinese": "建築歷史"
