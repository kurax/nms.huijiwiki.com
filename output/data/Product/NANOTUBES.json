  "PinObjectiveTip": {
    "English": "Craft <span class=\"name name-commodity\">Carbon Nanotubes</span> from <span class=\"name name-fuel\">Carbon</span>. Use <span class=\"name name-img\">PRODMENU</span> to craft in empty <span class=\"name name-technology\">Inventory Slots</span>.<br>Gather <span class=\"name name-fuel\">Carbon</span> from plants and trees using the <span class=\"name name-technology\">Mining Laser</span>. Fire the laser with <span class=\"name name-img\">ATTACK</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-fuel\">碳</span>制作<span class=\"name name-commodity\">碳纳米管</span>。使用<span class=\"name name-img\">PRODMENU</span>在空置<span class=\"name name-technology\">库存栏位</span>中制作。<br>使用<span class=\"name name-technology\">开采激光</span>从植物和树中收集<span class=\"name name-fuel\">碳</span>。使用<span class=\"name name-img\">ATTACK</span>发射激光。",
    "TencentChinese": "使用<span class=\"name name-fuel\">碳</span>制作<span class=\"name name-commodity\">碳纳米管</span>。使用<span class=\"name name-img\">PRODMENU</span>在空置<span class=\"name name-technology\">库存栏位</span>中制作。<br>使用<span class=\"name name-technology\">开采激光</span>从植物和树中收集<span class=\"name name-fuel\">碳</span>。使用<span class=\"name name-img\">ATTACK</span>发射激光。",
    "TraditionalChinese": "使用<span class=\"name name-fuel\">碳</span>製作<span class=\"name name-commodity\">奈米碳管</span>。使用 <span class=\"name name-img\">PRODMENU</span> 在空的<span class=\"name name-technology\">道具欄位</span>製作。<br>使用<span class=\"name name-technology\">採礦雷射</span>從植物和樹木收集<span class=\"name name-fuel\">碳</span>。按下 <span class=\"name name-img\">ATTACK</span> 發射雷射光束。"
  },
