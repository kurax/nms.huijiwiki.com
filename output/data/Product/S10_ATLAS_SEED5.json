  "ID": "S10_ATLAS_SEED5",
  "Name": {
    "English": "SEED OF HOPE",
    "SimplifiedChinese": "希望之种",
    "TraditionalChinese": "希望種子"
  },
  "NameLower": {
    "English": "Seed of Hope",
    "SimplifiedChinese": "希望之种",
