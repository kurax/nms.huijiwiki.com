  "PinObjective": {
    "English": "Craft or refine Magno-Gold",
    "SimplifiedChinese": "制作或精炼镍锰金",
    "TencentChinese": "制作或精炼镍锰金",
    "TraditionalChinese": "製作或精製磁金"
  },
  "PinObjectiveTip": {
    "English": "Craft or refine Magno-Gold from <span class=\"name name-earth\">Phosphorus</span> and <span class=\"name name-technology\">Ionized Cobalt</span>. Refining advanced products requires a <span class=\"name name-technology\">Large Refiner</span>.<br>Phosphorus is found in large deposits on <span class=\"name name-fuel\">scorched planets</span> with an <span class=\"name name-technology\">Analysis Visor</span>.<br>Refine Ionized Cobalt from <span class=\"name name-technology\">Cobalt</span>, which is harvested from <span class=\"name name-technology\">subterranean mineral deposits</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-earth\">磷</span>和<span class=\"name name-technology\">离子钴</span>制作或精炼出镍锰金。精炼先进的产品需要<span class=\"name name-technology\">大型精炼机</span>。<br>磷能在<span class=\"name name-fuel\">烧灼星球</span>上使用<span class=\"name name-technology\">分析面甲</span>在大型矿床中找到。<br>从<span class=\"name name-technology\">钴</span>中精炼出离子钴，钴能从<span class=\"name name-technology\">水下矿藏</span>中采集到。",
    "TencentChinese": "使用<span class=\"name name-earth\">磷</span>和<span class=\"name name-technology\">离子钴</span>制作或精炼出镍锰金。精炼先进的产品需要<span class=\"name name-technology\">大型精炼机</span>。<br>磷能在<span class=\"name name-fuel\">焦土星球</span>上使用<span class=\"name name-technology\">分析面甲</span>在大型矿床中找到。<br>从<span class=\"name name-technology\">钴</span>中精炼出离子钴，钴能从<span class=\"name name-technology\">水下矿藏</span>中采集到。",
    "TraditionalChinese": "將<span class=\"name name-earth\">磷</span>及<span class=\"name name-technology\">離子化鈷</span>製作或精製成磁金。精製先進產品需使用<span class=\"name name-technology\">大型精製機</span>。<br>磷可在<span class=\"name name-fuel\">焦土星球</span>的大型資源產地，用<span class=\"name name-technology\">分析護目鏡</span>找到。<br>將<span class=\"name name-technology\">地底礦資源產地</span>所採收的<span class=\"name name-technology\">鈷</span>精製成離子化鈷。"
  },
