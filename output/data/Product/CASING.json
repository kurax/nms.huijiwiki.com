  "PinObjectiveTip": {
    "English": "Craft <span class=\"name name-commodity\">Metal Plating</span> from <span class=\"name name-earth\">Ferrite Dust</span>. Use <span class=\"name name-img\">PRODMENU</span> to craft in empty <span class=\"name name-technology\">Inventory Slots</span>.<br>Harvest <span class=\"name name-earth\">Ferrite Dust</span> from small rocks using the <span class=\"name name-technology\">Mining Laser</span>. Fire the laser with <span class=\"name name-img\">ATTACK</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-earth\">铁氧体粉末</span>制作<span class=\"name name-commodity\">金属电镀</span>。使用<span class=\"name name-img\">PRODMENU</span>在空置<span class=\"name name-technology\">栏位</span>中制作。<br>使用<span class=\"name name-technology\">开采激光</span>从小岩石块中采集<span class=\"name name-earth\">铁氧体粉末</span>。按下<span class=\"name name-img\">ATTACK</span>发射激光。",
    "TencentChinese": "使用<span class=\"name name-earth\">铁氧体粉末</span>制作<span class=\"name name-commodity\">金属电镀</span>。使用<span class=\"name name-img\">PRODMENU</span>在空置<span class=\"name name-technology\">栏位</span>中制作。<br>使用<span class=\"name name-technology\">开采激光</span>从小岩石块中采集<span class=\"name name-earth\">铁氧体粉末</span>。按下<span class=\"name name-img\">ATTACK</span>发射激光。",
    "TraditionalChinese": "使用<span class=\"name name-earth\">鐵氧體粉塵</span>製作<span class=\"name name-commodity\">金屬電鍍</span>。使用<span class=\"name name-img\">PRODMENU</span>在空置<span class=\"name name-technology\">欄位</span>中製作。<br>使用<span class=\"name name-technology\">採礦雷射</span>從小石頭中採收<span class=\"name name-earth\">鐵氧體粉塵</span>。按下<span class=\"name name-img\">ATTACK</span>發射雷射。"
  },
