  "PinObjective": {
    "English": "Craft or refine Dirty Bronze",
    "SimplifiedChinese": "制作或精炼肮脏青铜",
    "TencentChinese": "制作或精炼肮脏青铜",
    "TraditionalChinese": "製作或精製汙銅"
  },
  "PinObjectiveTip": {
    "English": "Craft or refine Dirty Bronze from <span class=\"name name-earth\">Pyrite</span> and <span class=\"name name-earth\">Pure Ferrite</span>. Refining advanced products requires a <span class=\"name name-technology\">Large Refiner</span>.<br>Pyrite is found in large deposits on <span class=\"name name-stellar\">barren planets</span> with an <span class=\"name name-technology\">Analysis Visor</span>.<br>Refine Pure Ferrite from ferrite dust, found in common minerals.",
    "SimplifiedChinese": "使用<span class=\"name name-earth\">黄铁矿</span>和<span class=\"name name-earth\">纯铁氧体</span>制作或精炼出肮脏青铜。精炼先进的产品需要<span class=\"name name-technology\">大型精炼机</span>。<br>黄铁矿能在<span class=\"name name-stellar\">贫瘠星球</span>上使用<span class=\"name name-technology\">分析面甲</span>在大型矿床中找到。<br>使用寻常矿藏里找到的铁氧体粉末精炼出纯铁氧体。",
    "TencentChinese": "使用<span class=\"name name-earth\">黄铁矿</span>和<span class=\"name name-earth\">纯铁氧体</span>制作或精炼出肮脏青铜。精炼先进的产品需要<span class=\"name name-technology\">大型精炼机</span>。<br>黄铁矿能在<span class=\"name name-stellar\">贫瘠星球</span>上使用<span class=\"name name-technology\">分析面甲</span>在大型矿床中找到。<br>使用寻常矿藏里找到的铁氧体粉末精炼出纯铁氧体。",
    "TraditionalChinese": "將<span class=\"name name-earth\">黃鐵礦</span>及<span class=\"name name-earth\">純鐵氧體</span>製作或精製成汙銅。精製先進產品需使用<span class=\"name name-technology\">大型精製機</span>。<br>黃鐵礦可在<span class=\"name name-stellar\">荒蕪星球</span>的大型資源產地，用<span class=\"name name-technology\">分析護目鏡</span>找到。<br>將常見礦物中所找到的鐵氧體粉塵精製成純鐵氧體。"
  },
