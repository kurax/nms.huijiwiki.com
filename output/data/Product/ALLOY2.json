  "Name": {
    "English": "DIRTY BRONZE",
    "SimplifiedChinese": "肮脏青铜",
    "TencentChinese": "肮脏青铜",
    "TraditionalChinese": "汙銅"
  },
  "NameLower": {
    "English": "Dirty Bronze",
