  "PinObjective": {
    "English": "Craft or refine Herox",
    "SimplifiedChinese": "制作或精炼赫罗克斯",
    "TencentChinese": "制作或精炼赫罗克斯",
    "TraditionalChinese": "製作或精製赫羅克斯"
  },
  "PinObjectiveTip": {
    "English": "Craft or refine Herox from <span class=\"name name-earth\">Ammonia</span> and <span class=\"name name-earth\">Chlorine</span>. Refining advanced products requires a <span class=\"name name-technology\">Large Refiner</span>.<br>Ammonia is found in large deposits on <span class=\"name name-tradeable\">toxic planets</span> with an <span class=\"name name-technology\">Analysis Visor</span>.<br>Refine Chlorine from <span class=\"name name-tradeable\">Salt</span>, which is harvested from <span class=\"name name-technology\">underwater mineral deposits</span>.",
    "SimplifiedChinese": "使用<span class=\"name name-earth\">氨</span>和<span class=\"name name-earth\">氯</span>制作或精炼出赫罗克斯。精炼先进的产品需要<span class=\"name name-technology\">大型精炼机</span>。<br>氨能在<span class=\"name name-tradeable\">有毒星球</span>上使用<span class=\"name name-technology\">分析面甲</span>在大型矿床中找到。<br>从<span class=\"name name-tradeable\">盐</span>中精炼出氯，盐能从<span class=\"name name-technology\">水下矿藏</span>中采集到。",
    "TencentChinese": "使用<span class=\"name name-earth\">氨</span>和<span class=\"name name-earth\">氯</span>制作或精炼出赫罗克斯。精炼先进的产品需要<span class=\"name name-technology\">大型精炼机</span>。<br>氨能在<span class=\"name name-tradeable\">有毒星球</span>上使用<span class=\"name name-technology\">分析面甲</span>在大型矿床中找到。<br>从<span class=\"name name-tradeable\">盐</span>中精炼出氯，盐能从<span class=\"name name-technology\">水下矿藏</span>中采集到。",
    "TraditionalChinese": "將<span class=\"name name-earth\">氨</span>及<span class=\"name name-earth\">氯</span>製作或精製成赫羅克斯。精製先進產品需使用<span class=\"name name-technology\">大型精製機</span>。<br>氨可在<span class=\"name name-tradeable\">毒性星球</span>的大型資源產地，用<span class=\"name name-technology\">分析護目鏡</span>找到。<br>將<span class=\"name name-technology\">水底礦資源產地</span>所採收的<span class=\"name name-tradeable\">鹽</span>精製成氯。"
  },
