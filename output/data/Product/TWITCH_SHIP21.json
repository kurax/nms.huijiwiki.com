{
  "ID": "TWITCH_SHIP21",
  "Name": {
    "English": "HIWAMIHA OF DESTINY",
    "SimplifiedChinese": "命运的西瓦米哈",
    "TraditionalChinese": "命運的希瓦米哈"
  },
  "NameLower": {
    "English": "Hiwamiha of Destiny",
    "SimplifiedChinese": "命运的西瓦米哈",
    "TraditionalChinese": "命運的希瓦米哈"
  },
  "Subtitle": {
    "English": "Exclusive Spacecraft",
    "SimplifiedChinese": "专属飞船",
    "TraditionalChinese": "特殊太空船"
  },
  "Description": {
    "English": "An exclusive <span class=\"name name-stellar\">Starship</span>. This smuggler's craft is shielded by superheated <span class=\"name name-technology\">ablative armour</span>, and equipped with <span class=\"name name-technology\">scan deflector</span> technology to disguise contraband cargo from system authorities.<br><br><span class=\"name name-stellar\">Claim</span> this ship to add it to your collection, or <span class=\"name name-stellar\">Exchange</span> it with your current ship. While on a planet, summon ships from the Quick Menu (<span class=\"name name-img\">QUICK_MENU</span>).",
    "SimplifiedChinese": "一艘专属<span class=\"name name-stellar\">飞船</span>。这艘走私飞船拥有过热<span class=\"name name-technology\">烧蚀装甲</span>保护，并且能够凭借<span class=\"name name-technology\">扫描偏导器</span>技术伪装携带的违禁品货品以骗过星系当局。<br><br><span class=\"name name-stellar\">收取</span>这艘飞船，将它加入你的收藏，或与你现在的飞船<span class=\"name name-stellar\">交换</span>。在行星上时，使用快捷菜单（<span class=\"name name-img\">QUICK_MENU</span>）召唤飞船。",
    "TraditionalChinese": "一艘特殊<span class=\"name name-stellar\">太空船</span>。這艘走私者太空船由過熱<span class=\"name name-technology\">燒蝕裝甲</span>所保護，並配有<span class=\"name name-technology\">掃描反射器</span>，可對星系當局隱瞞禁運品貨物的存在。<br><br><span class=\"name name-stellar\">領取</span>這艘船加入你的收藏，或是與目前太空船<span class=\"name name-stellar\">交換</span>。在星球上時，可利用快捷選單 (<span class=\"name name-img\">QUICK_MENU</span>) 召喚太空船。"
  },
