{
  "_Table": "Product",
  "ID": "FIENDCORE",
  "Name": {
    "English": "LARVAL CORE",
    "SimplifiedChinese": "幼虫核心",
    "TencentChinese": "幼虫核心",
    "TraditionalChinese": "蟲核"
  },
  "NameLower": {
    "English": "Larval Core",
