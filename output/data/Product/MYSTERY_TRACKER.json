  "ID": "MYSTERY_TRACKER",
  "Name": {
    "English": "HISTORIOGRAPHICAL DOSIMETER",
    "SimplifiedChinese": "史学剂量仪",
    "TraditionalChinese": "史學史劑量計"
  },
  "NameLower": {
    "English": "Historiographical Dosimeter",
    "SimplifiedChinese": "史学剂量仪",
    "TraditionalChinese": "史學史劑量計"
